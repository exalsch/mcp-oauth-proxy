# Public HTTPS URL Caddy serves (no trailing slash)
MCP_PROXY_PUBLIC_URL=https://mcp.example.tld

# argon2 hash of your access secret — generate with:
#   docker compose run --rm proxy mcp-oauth-proxy-hash 'your-strong-secret'
MCP_PROXY_ACCESS_SECRET_HASH=

# --- Backend: single server (default) ---
# One stdio MCP server. Its tools are served unprefixed.
MCP_BACKEND_COMMAND=uvx
MCP_BACKEND_ARGS=mcp-obsidian

# Backend env — forwarded to the child process (prefix MCP_BACKEND_ENV_)
MCP_BACKEND_ENV_OBSIDIAN_API_KEY=
MCP_BACKEND_ENV_OBSIDIAN_HOST=100.64.0.2
MCP_BACKEND_ENV_OBSIDIAN_PORT=27124
MCP_BACKEND_ENV_OBSIDIAN_PROTOCOL=https

# --- Backend: multiple servers (optional) ---
# Point at a mounted JSON file (Claude-desktop `mcpServers` shape) to expose
# several MCP servers behind one connector. When set, this OVERRIDES the single
# MCP_BACKEND_* vars above. With >1 server, tools are namespaced by server key
# (e.g. obsidian_..., github_...). See deploy/servers.example.json.
# MCP_SERVERS_CONFIG=/data/servers.json

# Optional tuning
MCP_PROXY_HOST=0.0.0.0
MCP_PROXY_PORT=8000
